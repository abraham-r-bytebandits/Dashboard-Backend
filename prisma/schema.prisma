generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  LOCKED
  DELETED
}

enum AuthProviderType {
  GOOGLE
  FACEBOOK
  APPLE
}

enum AuditActionType {
  SIGNUP
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  ACCOUNT_DELETED
  CREATE
  UPDATE
  DELETE
  MARK_PAID
  GENERATE_REPORT
}

enum EntityType {
  USER
  CLIENT
  INVOICE
  INVOICE_PAYMENT
  EXPENSE
  CONTRIBUTION
  TRANSACTION
  REPORT
  SITE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionCategory {
  REVENUE
  EXPENSE
  CAPITAL
  INVOICE_PAYMENT
  ADJUSTMENT
  REFUND
  WITHDRAWAL
  DEPOSIT
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ExpenseType {
  FIXED
  OPERATIONAL
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  UPI
  WALLET
  CHEQUE
  OTHER
}

enum ReportType {
  FINANCIAL_SUMMARY
  REVENUE_REPORT
  EXPENSE_REPORT
  INVOICE_REPORT
  CLIENT_REPORT
  CASHFLOW_REPORT
}

enum ReportStatus {
  PENDING
  GENERATED
  FAILED
}

//////////////////////////////////////////////////
// ACCOUNT & AUTH
//////////////////////////////////////////////////

model Account {
  id              BigInt        @id @default(autoincrement())
  publicId        String        @unique @db.Char(36)
  email           String        @unique
  username        String        @unique
  status          AccountStatus @default(PENDING_VERIFICATION)
  isEmailVerified Boolean       @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  credential         Credential?
  sessions           Session[]
  providers          AuthProvider[]
  emailVerifications EmailVerification[]
  roles              AccountRole[]
  profile            UserProfile?

  authAuditLogs     AuthAuditLog[]
  activityAuditLogs ActivityAuditLog[]

  createdClients        Client[]            @relation("CreatedClients")
  createdInvoices       Invoice[]           @relation("CreatedInvoices")
  createdExpenses       Expense[]           @relation("CreatedExpenses")
  paidExpenses          Expense[]           @relation("PaidExpenses")
  createdContributions  Contribution[]      @relation("CreatedContributions")
  createdTransactions   Transaction[]       @relation("CreatedTransactions")
  generatedReports      Report[]            @relation("GeneratedReports")
  createdSites          Site[]              @relation("CreatedSites")

  @@index([email])
  @@index([username])
}

model Credential {
  id              BigInt @id @default(autoincrement())
  accountPublicId String @unique

  passwordHash      String
  passwordChangedAt DateTime?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

model Session {
  id               BigInt    @id @default(autoincrement())
  accountPublicId  String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)

  @@index([accountPublicId, revokedAt])
}

model AuthProvider {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  provider       AuthProviderType
  providerUserId String
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime         @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model EmailVerification {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  email     String
  tokenHash String
  ipAddress String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

//////////////////////////////////////////////////
// ROLES & PERMISSIONS
//////////////////////////////////////////////////

model Role {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  permissions RolePermission[]
  accounts    AccountRole[]
}

model Permission {
  id          BigInt           @id @default(autoincrement())
  code        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       BigInt
  permissionId BigInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AccountRole {
  accountPublicId String
  roleId          BigInt
  assignedAt      DateTime @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([accountPublicId, roleId])
}

//////////////////////////////////////////////////
// USER PROFILE
//////////////////////////////////////////////////

model UserProfile {
  id              BigInt @id @default(autoincrement())
  accountPublicId String @unique

  firstName    String
  lastName     String
  phone        String?
  profileImage String?   @db.Text
  dateOfBirth  DateTime?
  gender       String?

  account Account @relation(fields: [accountPublicId], references: [publicId], onDelete: Cascade)
}

//////////////////////////////////////////////////
// CLIENTS
//////////////////////////////////////////////////

model Client {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(uuid())
  name        String
  email       String?
  phone       String?
  companyName String?
  avatar      String?  @db.Text

  billingAddressLine1 String?
  billingAddressLine2 String?
  city                String?
  state               String?
  country             String?
  postalCode          String?

  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByPublicId String?
  createdBy         Account?   @relation("CreatedClients", fields: [createdByPublicId], references: [publicId], onDelete: SetNull)

  invoices ClientInvoice[]

  @@index([name])
  @@index([email])
  @@index([createdByPublicId])
}

//////////////////////////////////////////////////
// INVOICES
//////////////////////////////////////////////////

model Invoice {
  id            BigInt        @id @default(autoincrement())
  publicId      String        @unique @default(uuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(PENDING)

  title          String?
  featureProject String?
  description    String?       @db.Text

  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0.00) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0.00) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  receivedAmount Decimal       @default(0.00) @db.Decimal(12, 2)
  balanceDue     Decimal       @db.Decimal(12, 2)

  currency    String           @default("INR")
  issuedDate  DateTime
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdByPublicId String?
  createdBy         Account?        @relation("CreatedInvoices", fields: [createdByPublicId], references: [publicId], onDelete: SetNull)

  clients      ClientInvoice[]
  items        InvoiceItem[]
  payments     InvoicePayment[]
  transactions Transaction[]

  @@index([invoiceNumber])
  @@index([status])
  @@index([issuedDate])
  @@index([dueDate])
  @@index([createdByPublicId])
}

model ClientInvoice {
  clientId  BigInt
  invoiceId BigInt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@id([clientId, invoiceId])
  @@index([invoiceId])
}

model InvoiceItem {
  id        BigInt @id @default(autoincrement())
  invoiceId BigInt

  itemName     String
  description  String? @db.Text
  quantity     Int     @default(1)
  unitPrice    Decimal @db.Decimal(12, 2)
  taxPercent   Decimal @default(0.00) @db.Decimal(5, 2)
  discount     Decimal @default(0.00) @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoicePayment {
  id        BigInt        @id @default(autoincrement())
  publicId  String        @unique @default(uuid())
  invoiceId BigInt

  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  referenceNo   String?
  notes         String?       @db.Text
  paidAt        DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice      Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([invoiceId])
  @@index([paidAt])
}

//////////////////////////////////////////////////
// EXPENSES
//////////////////////////////////////////////////

model Expense {
  id          BigInt        @id @default(autoincrement())
  publicId    String        @unique @default(uuid())
  expenseId   String        @unique              // Auto-generated: #FIX001 or #OPE001
  expenseType ExpenseType   @default(OPERATIONAL)
  title       String
  category    String
  description String?       @db.Text
  comments    String?       @db.Text

  amount      Decimal       @db.Decimal(12, 2)
  expenseDate DateTime
  dueDate     DateTime?
  status      ExpenseStatus @default(PENDING)

  recurring   Boolean       @default(false)
  frequency   String?                            // "monthly" or "yearly"

  vendorName     String?
  paymentMethod  PaymentMethod?
  receiptUrl     String?       @db.Text
  notes          String?       @db.Text

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  paidByPublicId    String?
  paidBy            Account?       @relation("PaidExpenses", fields: [paidByPublicId], references: [publicId], onDelete: SetNull)

  createdByPublicId String?
  createdBy         Account?       @relation("CreatedExpenses", fields: [createdByPublicId], references: [publicId], onDelete: SetNull)

  transactions Transaction[]

  @@index([expenseType])
  @@index([category])
  @@index([expenseDate])
  @@index([dueDate])
  @@index([status])
  @@index([paidByPublicId])
  @@index([createdByPublicId])
}

//////////////////////////////////////////////////
// CAPITAL CONTRIBUTIONS
//////////////////////////////////////////////////

model Contribution {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(uuid())
  contributorName String
  amount      Decimal  @db.Decimal(12, 2)
  contributionDate DateTime
  notes       String?  @db.Text
  color       String?  // optional UI color like #2563eb

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByPublicId String?
  createdBy         Account?      @relation("CreatedContributions", fields: [createdByPublicId], references: [publicId], onDelete: SetNull)

  transactions Transaction[]

  @@index([contributorName])
  @@index([contributionDate])
  @@index([createdByPublicId])
}

//////////////////////////////////////////////////
// TRANSACTIONS / LEDGER
//////////////////////////////////////////////////

model Transaction {
  id          BigInt              @id @default(autoincrement())
  publicId    String              @unique @default(uuid())
  type        TransactionType
  category    TransactionCategory

  amount      Decimal             @db.Decimal(12, 2)
  currency    String              @default("INR")
  date        DateTime
  description String?             @db.Text
  referenceNo String?

  invoiceId         BigInt?
  invoicePaymentId  BigInt?
  expenseId         BigInt?
  contributionId    BigInt?

  createdByPublicId String?
  createdBy         Account?          @relation("CreatedTransactions", fields: [createdByPublicId], references: [publicId], onDelete: SetNull)

  invoice        Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoicePayment InvoicePayment?  @relation(fields: [invoicePaymentId], references: [id], onDelete: SetNull)
  expense        Expense?         @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  contribution   Contribution?    @relation(fields: [contributionId], references: [id], onDelete: SetNull)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([invoiceId])
  @@index([expenseId])
  @@index([contributionId])
  @@index([invoicePaymentId])
  @@index([createdByPublicId])
}

//////////////////////////////////////////////////
// REPORTS
//////////////////////////////////////////////////

model Report {
  id          BigInt       @id @default(autoincrement())
  publicId    String       @unique @default(uuid())
  name        String
  type        ReportType
  status      ReportStatus @default(PENDING)

  fromDate    DateTime?
  toDate      DateTime?
  format      String       // pdf, csv, xlsx
  fileUrl     String?      @db.Text
  errorMessage String?     @db.Text

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  generatedByPublicId String?
  generatedBy         Account? @relation("GeneratedReports", fields: [generatedByPublicId], references: [publicId], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([generatedByPublicId])
}

//////////////////////////////////////////////////
// AUDIT LOGS
//////////////////////////////////////////////////

model AuthAuditLog {
  id              BigInt @id @default(autoincrement())
  accountPublicId String

  action    AuditActionType
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountPublicId], references: [publicId])
}

model ActivityAuditLog {
  id              BigInt  @id @default(autoincrement())
  accountPublicId String?

  action     AuditActionType
  entityType EntityType
  entityId   String

  oldData Json?
  newData Json?

  createdAt DateTime @default(now())

  account Account? @relation(fields: [accountPublicId], references: [publicId])
}

//////////////////////////////////////////////////
// SITES
//////////////////////////////////////////////////

model Site {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(uuid())
  name      String
  userName  String
  url       String
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByPublicId String?
  createdBy         Account? @relation("CreatedSites", fields: [createdByPublicId], references: [publicId], onDelete: SetNull)

  @@index([createdByPublicId])
  @@index([name])
}
